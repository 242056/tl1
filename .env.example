PORT=3000
# Таймаут для MOEX, profinansy и прочих быстрых HTTP-запросов (сек)
HTTP_TIMEOUT_SEC=15
# Таймаут только для запроса к LLM (сек). sonar-deep-research: 300–900
LLM_TIMEOUT_SEC=300
# Опционально: seed для воспроизводимости (если провайдер поддерживает)
# LLM_SEED=42
LLM_PROVIDER=aitunnel
LLM_TEMPERATURE=0

LLM_BASE_URL=https://api.perplexity.ai
LLM_API_KEY=
LLM_MODEL=sonar
# Опционально: отдельная модель для дозаполнения пустых метрик (быстрее/дешевле)
# LLM_GAP_MODEL=sonar
LLM_ENDPOINT=/chat/completions

# Официальные источники (опционально): если URL заданы — парсер пробует их до LLM
SRC_INSTRUMENT_CARD_URL=
SRC_VTB_RESEARCH_URL=
SRC_FIN_REPORTS_URL=
SOURCES_API_TOKEN=
